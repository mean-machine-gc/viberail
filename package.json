{
  "name": "viberail",
  "version": "0.2.1",
  "description": "Typed behavioral specifications — the blueprint for your functions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reporters/*": {
      "types": "./dist/reporters/*.d.ts",
      "default": "./dist/reporters/*.js"
    }
  },
  "bin": {
    "viberail": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "spec",
    "specification",
    "behavioral",
    "testing",
    "decision-table",
    "dependency-graph",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mean-machine-gc/viberail.git"
  },
  "homepage": "https://github.com/mean-machine-gc/viberail#readme",
  "bugs": {
    "url": "https://github.com/mean-machine-gc/viberail/issues"
  },
  "license": "MIT",
  "dependencies": {
    "glob": "^13.0.6"
  },
  "peerDependencies": {
    "jest": ">=29.0.0",
    "tsx": ">=4.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "jest": {
      "optional": true
    },
    "tsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0"
  }
}
